DPATH       := $($(DOCKER_SYNCD_MRVL_PRESTERA)_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) $(PLATFORM_PATH)/docker-syncd-mrvl-prestera.mk $(PLATFORM_PATH)/docker-syncd-mrvl-prestera.dep $(PLATFORM_PATH)/sai.mk
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(DPATH))

$(DOCKER_SYNCD_MRVL_PRESTERA)_CACHE_MODE  := GIT_CONTENT_SHA
$(DOCKER_SYNCD_MRVL_PRESTERA)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(DOCKER_SYNCD_MRVL_PRESTERA)_DEP_FILES   := $(DEP_FILES)

