DPATH       := $($(DOCKER_SYNCD_MRVL_VS)_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) $(PLATFORM_PATH)/docker-syncd-mrvl-vs.mk $(PLATFORM_PATH)/docker-syncd-mrvl-vs.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(DPATH))

$(DOCKER_SYNCD_MRVL_VS)_CACHE_MODE  := GIT_CONTENT_SHA
$(DOCKER_SYNCD_MRVL_VS)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(DOCKER_SYNCD_MRVL_VS)_DEP_FILES   := $(DEP_FILES)
